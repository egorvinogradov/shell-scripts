#!/usr/bin/env bash
set -euo pipefail

# corsair-clipboard — send text/file to Ubuntu server clipboard + auto-copy
# Usage:
#   corsair-clipboard "some text"
#   corsair-clipboard -f ~/Desktop/notes.txt
#   echo "hello" | corsair-clipboard

SSH_HOST="user@192.168.12.152"

# Remote command: write stdin to file, then copy to clipboard in background
# Finds XAUTHORITY for XWayland (needed when SSHing into a Wayland session)
REMOTE_CMD='
cat > $HOME/Downloads/clipboard-egor.txt &&
XAUTH=$(ls /run/user/$(id -u)/.mutter-Xwaylandauth.* 2>/dev/null | head -1) &&
XAUTHORITY=${XAUTH:-$HOME/.Xauthority} DISPLAY=:0 nohup xclip -selection clipboard < $HOME/Downloads/clipboard-egor.txt >/dev/null 2>&1 &
'

usage() {
  echo "Usage: corsair-clipboard <text>"
  echo "       corsair-clipboard -f <file>"
  echo "       echo <text> | corsair-clipboard"
  exit 1
}

if [ $# -eq 0 ]; then
  # Pipe mode: forward stdin as-is
  if [ -t 0 ]; then
    usage
  fi
  cat | ssh "$SSH_HOST" "$REMOTE_CMD"
elif [ "$1" = "-f" ]; then
  # File mode: forward file content as-is
  [ $# -lt 2 ] && usage
  [ ! -f "$2" ] && echo "Error: file not found: $2" && exit 1
  cat "$2" | ssh "$SSH_HOST" "$REMOTE_CMD"
elif [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
  usage
else
  # Direct text mode: no trailing newline
  printf "%s" "$*" | ssh "$SSH_HOST" "$REMOTE_CMD"
fi

echo "✓ Copied to $SSH_HOST clipboard"
